    "betterquesting:10": {
      "desc:8": "HBM's Nuclear Tech Mod is a massive content mod adding nuclear reactors, oil processing, mining drills, missiles, advanced machinery, and endgame content. This questline guides you from your first anvil to thermonuclear weapons and beyond.\n\nProgression Steps:\n    Blacksmithing - Anvils, presses, stamps, and basic metallurgy\n    The Factory - Assembly machines, generators, and automation\n    The Electrical Age - Soldering, circuits, and chemical processing\n    Oil & Power - Refineries, steam power, and advanced energy\n    The Foundry - Crucibles, alloys, and high-speed steel\n    Nuclear Age - Reactors, centrifuges, and radioactive materials",
      "icon:10": {
        "Count:3": 1,
        "id:8": "hbm:book_guide",
        "Damage:2": 0
      },
      "name:8": "HBM's Nuclear Tech",
      "visibility:8": "ALWAYS"
    }
  },
