  "properties:10": {
    "betterquesting:10": {
      "desc:8": "Welcome to the HBM mid-game! This questline covers the critical progression path from early oil processing through advanced petrochemistry, secondary materials, and industrial-scale refining. Master finding and extracting crude oil, build refineries and cracking towers, produce polymers and advanced chemicals, and work your way toward the complex vacuum refining and catalytic reforming chains. Along the way you will also learn about industrial machines, byproduct processing, and the many chemical pathways that unlock HBM's most powerful mid-game technologies. Each phase builds upon the last — follow the dependencies in order for a smooth progression.",
      "icon:10": {
        "Count:3": 1,
        "id:8": "hbm:fluid_barrel_full",
        "Damage:2": 10
      },
      "name:8": "HBM: Mid Game",
      "visibility:8": "ALWAYS"
    }
  },
