  "properties:10": {
    "betterquesting:10": {
      "desc:8": "Welcome to the Nuclear Age! This questline covers the ultimate end-game progression in HBM's Nuclear Tech Mod. Begin by mastering advanced nuclear fuel processing with Yellowcake and the ZIRNOX reactor, then progress through PWR reactors, PUREX reprocessing, and waste management. Build the Cyclotron and RBMK for exotic isotopes, harness Corium and Fusion power, and manufacture end-game materials like Schrabidium, Antimatter, and Dineutronium. culminates with the Particle Accelerator, Exposure Chamber, and end-game infrastructure including the Leviathan Steam Turbine and Asteroid Mining Ship.",
      "icon:10": {
        "Count:3": 1,
        "id:8": "hbm:ingot_schrabidium",
        "Damage:2": 0
      },
      "name:8": "Nuclear Age",
      "visibility:8": "ALWAYS"
    }
  },
